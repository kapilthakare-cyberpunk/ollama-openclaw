[Unit]
Description=OpenClaw Dashboard
After=network.target

[Service]
Type=simple
User=kapilt
WorkingDirectory=/home/kapilt/Projects/ollama-openclaw/dashboard
ExecStart=/usr/bin/node /home/kapilt/Projects/ollama-openclaw/dashboard/server.js
Restart=always
RestartSec=10
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
